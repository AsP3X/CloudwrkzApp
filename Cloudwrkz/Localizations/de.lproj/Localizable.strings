"privacy_policy.title" = "Datenschutzrichtlinie";

"privacy_policy.last_updated" = "Zuletzt aktualisiert: M?rz 2026";

"privacy_policy.controller_title" = "Verantwortlicher";

"privacy_policy.controller_body" = "Verantwortlicher f?r die Datenverarbeitung in der Cloudwrkz-App ist der Betreiber Ihrer Cloudwrkz-Instanz. Bei Nutzung des offiziellen Cloudwrkz-Dienstes (cloudwrkz.com) ist der Verantwortliche die Cloudwrkz GmbH. Bei selbst gehosteten Installationen ist Ihre Organisation verantwortlich.\n\nF?r Fragen zum Datenschutz wenden Sie sich an Ihren Administrator oder an privacy@cloudwrkz.com.";

"privacy_policy.data_collection_title" = "Welche Daten wir erheben";

"privacy_policy.data_collection_body" = "Wir erheben und verarbeiten folgende Kategorien personenbezogener Daten:\n\n? Kontodaten: Name, E-Mail-Adresse und Passwort (verschl?sselt) zur Authentifizierung.\n? Profildaten: Vorname, Nachname und optionales Profilbild.\n? Ger?temetadaten: Ger?tetyp (Mobiltelefon/Tablet), Betriebssystemversion und App-Version ? werden bei der Anmeldung zur Sitzungsverwaltung ?bermittelt.\n? Nutzungsdaten: Tickets, Aufgaben, Zeiteintr?ge (einschlie?lich textbasierter Ortsbeschreibungen), Links und andere von Ihnen erstellte Inhalte.\n? Technische Daten: Authentifizierungstoken sicher im iOS-Schl?sselbund gespeichert; App-Einstellungen lokal auf Ihrem Ger?t gespeichert.\n\nWir erheben NICHT:\n? GPS- oder pr?zise Standortdaten\n? Kontakte, Kalender oder Gesundheitsdaten\n? Werbeidentifikatoren oder Tracking-Daten\n? Daten von Drittanbieter-Analyse-SDKs";

"privacy_policy.legal_basis_title" = "Rechtsgrundlage der Verarbeitung";

"privacy_policy.legal_basis_body" = "Wir verarbeiten Ihre Daten auf folgenden Rechtsgrundlagen (DSGVO Art. 6):\n\n? Vertragserf?llung (Art. 6 Abs. 1 lit. b): Verarbeitung, die f?r die Bereitstellung des Cloudwrkz-Dienstes erforderlich ist, einschlie?lich Authentifizierung, Datenspeicherung und Funktionalit?t.\n? Berechtigte Interessen (Art. 6 Abs. 1 lit. f): Ger?temetadaten f?r Sitzungssicherheit und Betrugspr?vention.\n? Einwilligung (Art. 6 Abs. 1 lit. a): Optionale Funktionen wie Profilbild-Upload und biometrische Sperre. Sie k?nnen Ihre Einwilligung jederzeit widerrufen.";

"privacy_policy.third_party_title" = "Drittanbieterdienste";

"privacy_policy.third_party_body" = "Die App verbindet sich mit folgenden Drittanbieterdiensten:\n\n? OpenStreetMap Nominatim: Wird f?r textbasierte Adressvorschl?ge in der Zeiterfassung verwendet. Ihre Suchanfragen werden an nominatim.openstreetmap.org gesendet. Es werden keine pers?nlichen Identifikatoren ?bermittelt. Datenschutzrichtlinie von Nominatim: https://osmfoundation.org/wiki/Privacy_Policy\n? YouTube (img.youtube.com): Wird zum Laden von Vorschaubildern f?r Links mit YouTube-URLs verwendet. Es wird nur die Video-ID ?bertragen.\n\nWir geben Ihre personenbezogenen Daten nicht an Werbenetzwerke, Datenh?ndler oder Analyseanbieter weiter.";

